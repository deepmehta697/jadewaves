SEO_CONFIG_PATH=config/seo.config.json
SEO_SITE_URL=https://jadewavesenterprise.com
SEO_SITE_NAME=Jade Waves Enterprise
SEO_REPORT_DIR=reports/seo
SEO_GITHUB_REPO=deepmehta697/jadewaves

# Google Search Console / GA4 access
# Working Search Console property value for this site:
SEO_SEARCH_CONSOLE_PROPERTY=https://jadewavesenterprise.com/
# Numeric GA4 property ID, not the G- measurement ID.
SEO_GA4_PROPERTY_ID=527330659
# Absolute path to the downloaded Google service account JSON key file.
# Prefer storing this in config/seo.config.local.json instead of committing it.
SEO_GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Frontend tracking config
SEO_GA4_MEASUREMENT_ID=G-9BRL4JKNN6
SEO_ANALYTICS_FORM_SUBMIT_EVENT=submit_lead_form
SEO_ANALYTICS_LEAD_EVENT=generate_lead
